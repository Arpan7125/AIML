    "    display(corr.loc['daily_social_media_hours', key_vars].sort_values(ascending=False).round(3))\n",
    "\n",
    "print('Why categorical variables should not be included directly in correlation without encoding:')\n",
    "print('- Correlation assumes numeric distance/linearity. Categorical values are arbitrary codes, so correlation can become misleading.')\n",
    "print('- Need encoding (one-hot/ordinal) to create meaningful numeric representations before correlation.')\n"
