   "source": [
    "# Q6(a): Outliers using IQR method\n",
    "print('Q6(a): Outliers via IQR')\n",
    "cols = ['daily_social_media_hours','sleep_hours','stress_level','anxiety_level']\n",
    "for c in cols:\n",
    "    if c not in df.columns:\n",
    "        continue\n",
    "    q1 = df[c].quantile(0.25)\n",
    "    q3 = df[c].quantile(0.75)\n",
    "    iqr = q3 - q1\n",
    "    lower = q1 - 1.5 * iqr\n",
    "    upper = q3 + 1.5 * iqr\n",
    "    out_count = df[(df[c] < lower) | (df[c] > upper)][c].dropna().shape[0]\n",
    "    print(f"{c}: lower={lower:.3f}, upper={upper:.3f}, outliers_count={out_count}")\n"
   ]
  },
