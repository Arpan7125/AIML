   "source": [
    "# Q2(b): compare mean vs median for daily_social_media_hours and sleep_hours\n",
    "print('Q2(b): Mean vs Median + skewness')\n",
    "for col in ['daily_social_media_hours','sleep_hours']:\n",
    "    if col not in df.columns:\n",
    "        continue\n",
    "    mean_val = df[col].mean()\n",
    "    median_val = df[col].median()\n",
    "    skew_val = df[col].skew()\n",
    "    diff = mean_val - median_val\n",
    "    print(f"\nColumn: {col}")\n",
    "    print(f"  Mean   = {mean_val:.3f}")\n",
    "    print(f"  Median = {median_val:.3f}")\n",
    "    print(f"  Skew   = {skew_val:.3f}")\n",
    "    if abs(diff) < 1e-9:\n",
    "        print('  Interpretation: mean≈median -> roughly symmetric distribution')\n",
    "    elif diff > 0:\n",
    "        print('  Interpretation: mean>median -> right-skew / positive skew tendency')\n",
    "    else:\n",
    "        print('  Interpretation: mean<median -> left-skew / negative skew tendency')\n",
    "    if abs(skew_val) < 0.5:\n",
    "        print('  Skewness interpretation: close to symmetric')\n",
    "    elif skew_val > 0.5:\n",
    "        print('  Skewness interpretation: positive skew (right tail)')\n",
    "    else:\n",
    "        print('  Skewness interpretation: negative skew (left tail)')\n"
   ]
